# ─────────────────────────────────────────────────────────────
# .env.local.example
#
# Copia este archivo como .env.local y completa los valores.
# NUNCA subas .env.local a control de versiones (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────

# ── Configuración SMTP para el formulario de contacto ──────────
# Usa cualquier proveedor SMTP: Gmail (App Password), Mailtrap, AWS SES, etc.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=tu@email.com
SMTP_PASS=tu_password_smtp

# Email donde recibirás los mensajes del formulario de contacto
CONTACT_EMAIL_TO=max@masalsur.cl
CONTACT_EMAIL_CC=sebastianbriceno.1991@gmail.com

# ── Alternativas sin SMTP ──────────────────────────────────────
# Si prefieres Resend (https://resend.com):
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Si prefieres SendGrid (https://sendgrid.com):
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# ── URL pública del sitio (para SEO y Open Graph) ─────────────
NEXT_PUBLIC_SITE_URL=https://masalsur.cl

# ── API pública de contacto para builds estáticos en cPanel ───
# En Vercel puede omitirse para usar /api/contacto del mismo dominio.
NEXT_PUBLIC_CONTACT_API_URL=https://masalsur.vercel.app/api/contacto
